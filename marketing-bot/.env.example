# ── בוט Telegram ──────────────────────────────────────────────────────────────
# איך לקבל: פתח @BotFather → /newbot → קבל טוקן
TELEGRAM_TOKEN=your_telegram_bot_token_here

# ── Meta / Facebook Ads ───────────────────────────────────────────────────────
# איך לקבל: business.facebook.com → Settings → System Users
#            → צור System User (Admin) → Generate Token
#            → הרשאות: ads_management, ads_read, business_management, pages_read_engagement
META_ACCESS_TOKEN=your_meta_access_token_here

# איך לקבל: business.facebook.com → Accounts → Ad Accounts → העתק את ה-ID
# חייב להתחיל ב-act_
AD_ACCOUNT_ID=act_your_ad_account_id_here

# איך לקבל: עמוד הפייסבוק → About → Page ID (מספר בתחתית)
PAGE_ID=your_facebook_page_id_here

# ── Apify ─────────────────────────────────────────────────────────────────────
# איך לקבל: apify.com → Settings → Integrations → API tokens → Create new token
APIFY_API_TOKEN=your_apify_api_token_here

# מזהה הצ'אט שאליו ישלחו הפוסטים
# איך לקבל: שלח הודעה ל-@userinfobot ב-Telegram → תקבל את ה-ID שלך
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# פורט שרת ה-Webhook (ברירת מחדל: 8080)
WEBHOOK_PORT=8080
